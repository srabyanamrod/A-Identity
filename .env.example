# Copy to .env.local (or set in your host) and adjust per environment.

# Base URL of the deployed Mintlify docs site. In dev this defaults to
# http://localhost:3000 (see .env.development). In production this is the live
# Mintlify docs site. If left unset, the code falls back to the same live docs
# URL, so links always resolve.
VITE_DOCS_URL=https://a-identity.mintlify.site

# Base URL of the A-Identity MCP HTTP server.
#  - Local dev: point at your local backend.
#  - Production (Vercel): leave this EMPTY ("") so the frontend calls same-origin
#    paths (/health, /api/*, /mcp). vercel.json then proxies those to the Render
#    backend as first-party requests — this dodges ad blockers / privacy lists that
#    block *.onrender.com and would otherwise show a false "backend offline".
VITE_MCP_URL=http://localhost:3399

# WalletConnect / Reown project id (free, from cloud.reown.com). Enables the
# "WalletConnect (mobile)" option in the wallet picker. Public value (baked into
# the frontend build). Leave unset to hide WalletConnect. Set the same value in
# the Vercel project's env for production.
# VITE_WALLETCONNECT_PROJECT_ID=

# ── Backend (MCP/REST server) security — set these in the host env (e.g. Render) ──

# Session-token signing secret. REQUIRED in production: without it, tokens are signed
# with a public default and could be forged. On a prod-like host (RENDER / NODE_ENV=
# production / DATABASE_URL set) an unset value falls back to a RANDOM per-process
# secret (safe, but sessions don't survive a restart), and the server logs a warning.
# Set a strong, stable value (>=16 chars) so sessions persist across restarts.
# AUTH_SECRET=change-me-to-a-long-random-string

# CORS allowlist: comma-separated origins allowed to call the API cross-origin.
# Unset → '*' (fine for local Vite dev). In production set it to your site origin(s);
# the prod frontend uses a same-origin Vercel proxy, so this locks out other origins.
# ALLOWED_ORIGINS=https://a-identity.xyz,https://a-identity.vercel.app

# Circle developer platform (console.circle.com). With this set, the MCP server's
# /api/circle and get_circle_status perform a real authenticated ping.
# Sandbox keys look like TEST_API_KEY:<id>:<secret>.
# CIRCLE_API_KEY=
# CIRCLE_API_BASE=https://api.circle.com

# Passwordless email sign-in ("magic link") via Resend (resend.com). Backend-only,
# credential-gated: without RESEND_API_KEY the email path cleanly reports "not
# configured" and the UI falls back to wallet / guest. Set these in the Render env.
# RESEND_API_KEY=re_...
# MAGIC_FROM_EMAIL=A-Identity <onboarding@resend.dev>   # verify a domain to email arbitrary addresses (test sender only reaches your own)
# APP_URL=https://a-identity.vercel.app                 # base URL the emailed link points back to
