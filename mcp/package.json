{
  "name": "@a-identity/mcp",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "A-Identity MCP server, read-only multi-chain agent identity and reputation tools (no keys, no funds, no chain writes)",
  "bin": {
    "a-identity-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "compile": "node scripts/compile-contracts.mjs",
    "test": "npm run build && node --test dist/auth.test.js dist/reputation.test.js",
    "e2e": "node e2e.mjs",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "smoke": "node dist/smoke.js",
    "http-smoke": "node dist/http-smoke.js"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^9.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.22.0",
    "viem": "^2.52.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "solc": "^0.8.36",
    "typescript": "^5.9.3"
  }
}
