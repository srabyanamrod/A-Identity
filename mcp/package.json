{
  "name": "@a-identity/mcp",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "A-Identity MCP server, read-only multi-chain agent identity and reputation tools (no keys, no funds, no chain writes)",
  "bin": {
    "a-identity-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "compile": "node scripts/compile-contracts.mjs",
    "test": "npm run build && node --test dist/auth.test.js dist/reputation.test.js dist/chains/caip.test.js dist/chains/registry.test.js dist/chains/evm/adapter.test.js dist/chains/arc-parity.test.js dist/asp/risk.test.js dist/asp/tools.test.js dist/airdrop.test.js",
    "e2e": "node e2e.mjs",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "start:asp": "node dist/asp-gateway.js",
    "smoke": "node dist/smoke.js",
    "http-smoke": "node dist/http-smoke.js"
  },
  "dependencies": {
    "@circle-fin/adapter-viem-v2": "^1.13.0",
    "@circle-fin/bridge-kit": "^1.12.0",
    "@circle-fin/developer-controlled-wallets": "^9.2.0",
    "@circle-fin/x402-batching": "^3.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "viem": "^2.52.2",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@okxweb3/x402-core": "0.1.0",
    "@okxweb3/x402-evm": "0.2.1",
    "@okxweb3/x402-express": "0.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.21",
    "solc": "^0.8.36",
    "typescript": "^5.9.3"
  }
}
